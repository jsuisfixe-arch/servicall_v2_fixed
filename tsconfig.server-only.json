{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "jsx": "react",
    "allowImportingTsExtensions": false,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "ws"]
  },
  "include": ["server/**/*", "shared/**/*"],
  "exclude": ["client", "dist", "node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
