{
  "name": "servicall-v2",
  "version": "2.0.0",
  "description": "Plateforme SaaS de gestion d'appels et services professionnels",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/index.ts",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' vite build && pnpm exec esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --external:vite --external:../../vite.config --outdir=dist",
    "build:server": "tsc -p tsconfig.server-only.json",
    "build:client": "vite build",
    "start": "NODE_ENV=production node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "admin:init": "tsx server/scripts/seed-admin.ts",
    "db:seed": "tsx server/scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:watch": "vitest --watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=4096' tsc --noEmit",
    "docker:build": "docker build -t servicall:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "deploy:staging": "pnpm run build && pnpm run db:migrate && pm2 start ecosystem.config.js --env staging",
    "deploy:prod": "pnpm run build && pnpm run db:migrate && pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop servicall",
    "pm2:restart": "pm2 restart servicall",
    "pm2:logs": "pm2 logs servicall",
    "prepare": "husky install",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "dev:full": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "build:tsc": "pnpm run build:server && pnpm run build:client",
    "start:tsc": "NODE_ENV=production node dist/server/_core/index.js",
    "type-check": "NODE_OPTIONS='--max-old-space-size=4096' tsc --noEmit",
    "generate-css": "node server/scripts/generate-css.cjs",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report playwright-report"
  },
