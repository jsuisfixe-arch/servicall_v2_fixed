{
  "id": "logistique-suivi",
  "name": "Logistique Suivi",
  "industry": "logistique",
  "initialState": "accueil",
  "fallbackState": "clarification",
  "context": {
    "activity_type": "logistique_suivi",
    "num_suivi": null,
    "statut_colis": null
  },
  "states": [
    {
      "id": "accueil",
      "name": "Accueil",
      "onEnter": [
        { "type": "load_callcenter_script", "config": { "activity": "logistique_suivi" } },
        { "type": "speak_to_caller", "config": { "text": "{{pitch}}" } },
        { "type": "listen_and_understand", "config": { "timeout": 10 } }
      ],
      "transitions": [
        { "condition": "intent === 'track_package'", "targetState": "demande_suivi" }
      ]
    },
    {
      "id": "demande_suivi",
      "name": "Demande Suivi",
      "onEnter": [
        { "type": "speak_to_caller", "config": { "text": "{{questions_qualification[0].text}}" } },
        { "type": "listen_and_understand", "config": { "timeout": 15 } }
      ],
      "transitions": [
        { "condition": "entities.num_suivi", "targetState": "statut_temps_reel" }
      ]
    },
    {
      "id": "statut_temps_reel",
      "name": "Statut Temps Réel",
      "onEnter": [
        { "type": "query_database", "config": { "table": "shipments", "query": { "tracking_number": "{{entities.num_suivi}}" } } },
        { "type": "speak_to_caller", "config": { "text": "Votre colis est en cours de livraison. Serez-vous présent entre 14h et 16h ?" } },
        { "type": "listen_and_understand", "config": { "timeout": 10 } }
      ],
      "transitions": [
        { "condition": "intent === 'confirm'", "targetState": "finalisation_livraison" },
        { "condition": "intent === 'refuse'", "targetState": "reprogrammation" }
      ]
    },
    {
      "id": "reprogrammation",
      "name": "Reprogrammation",
      "onEnter": [
        { "type": "speak_to_caller", "config": { "text": "Je comprends. Quelle nouvelle date de livraison vous conviendrait ?" } },
        { "type": "listen_and_understand", "config": { "timeout": 15 } }
      ],
      "transitions": [
        { "condition": "entities.new_date", "targetState": "finalisation_reprogrammation" }
      ]
    },
    {
      "id": "finalisation_livraison",
      "name": "Finalisation Livraison",
      "onEnter": [
        { "type": "update_delivery_db", "config": { "status": "confirmed_presence" } },
        { "type": "speak_to_caller", "config": { "text": "Parfait, le livreur passera comme prévu. Merci et bonne journée." } }
      ],
      "transitions": []
    },
    {
      "id": "finalisation_reprogrammation",
      "name": "Finalisation Reprogrammation",
      "onEnter": [
        { "type": "reprogram_delivery", "config": { "date": "{{entities.new_date}}" } },
        { "type": "send_incident_sms_photo", "config": { "template": "reprogrammation_succes" } },
        { "type": "speak_to_caller", "config": { "text": "C'est noté. La nouvelle date de livraison est enregistrée. Un SMS de confirmation vous a été envoyé. Au revoir." } }
      ],
      "transitions": []
    }
  ]
}
